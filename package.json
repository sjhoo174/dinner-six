{
  "name": "dinner-six",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"API,UI\" -c \"magenta,cyan\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:api": "node backend/server.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "deploy:cloudflare": "npm run deploy:pages",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name dinner-six"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
